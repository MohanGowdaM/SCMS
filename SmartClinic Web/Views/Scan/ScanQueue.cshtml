@using SmartClinic.Web.Models.Scan

<div class="doctor-terminal-container">

    <!-- TOP STATS -->
    <div class="stats-grid">
        <div class="stat-card">
            <div class="stat-title">TOTAL</div>
            <h2 id="totalCount">0</h2>
        </div>
        <div class="stat-card success">
            <div class="stat-title">COMPLETED</div>
            <h2 id="completedCount">0</h2>
        </div>
        <div class="stat-card warning">
            <div class="stat-title">WAITING</div>
            <h2 id="waitingCount">0</h2>
        </div>
        <div class="stat-card hold">
            <div class="stat-title">HOLD</div>
            <h2 id="holdCount">0</h2>
        </div>
        <div class="stat-card danger">
            <div class="stat-title">SKIPPED</div>
            <h2 id="skipCount">0</h2>
        </div>
        <div class="stat-card review">
            <div class="stat-title">REVIEW</div>
            <h2 id="reviewCount">0</h2>
        </div>
    </div>
    <!-- MIDDLE GRID -->
    <div class="middle-grid">
        <!-- ACTION PANEL -->
        <div class="action-panel">
            <div class="btn-row">
                <button id="btnCall" class="action-btn primary">
                    📞 CALL
                </button>
                <button id="btnEnd" class="action-btn danger">
                    ⛔ END
                </button>
                <button id="btnRecall" class=" action-btn secondary">
                    🔄 RECALL
                </button>
                <button id="btnHold" class="action-btn warning">
                    ⏸ HOLD
                </button>
                <button id="btnSkip" class="action-btn dark">
                    ⏭ SKIP
                </button>
                <button id="btnNext" class="action-btn primary">
                    ➡ NEXT
                </button>
            </div>
        </div>
        <!-- CURRENTLY CALLED -->
        <div class="current-call-card">
            <small>CURRENTLY CALLED</small>
            <h1 id="currentToken">
                ---
            </h1>
            <h5 id="currentPatient">
                No Patient
            </h5>
            <!-- PAYMENT STATUS -->
            <div class="mt-2">
                <span id="paymentPendingBadge"
                      class="badge bg-warning text-dark px-3 py-2">
                    Payment Pending
                </span>
                <span id="paymentCompletedBadge"
                      class="badge bg-success px-3 py-2 d-none">
                    Payment Completed
                </span>
            </div>
            <small id="currentScan" class="d-block mt-2">
                ---
            </small>
        </div>
        <!-- NEXT 3 -->
        <div class="queue-card">
            <div class="card-header">
                NEXT 3 QUEUE
            </div>
            <div id="nextQueueList">
                <div class="text-muted">
                    No upcoming patients
                </div>
            </div>
        </div>
        <input type="hidden" id="currentTokenId" />
        <input type="hidden" id="currentRequestId" />
    </div>
    <!-- BOTTOM GRID -->
    <div class="bottom-grid">
        <!-- WAITING -->
        <div class="queue-card">
            <div class="card-header">
                WAITING QUEUE
            </div>
            <div id="waitingQueueList">
                <div class="text-muted">
                    No waiting patients
                </div>
            </div>
        </div>
        <!-- SKIPPED -->
        <div class="queue-card">
            <div class="card-header">
                SKIPPED QUEUE
            </div>
            <div id="skippedQueueList">
                <div class="text-muted">
                    No skipped patients
                </div>
            </div>
        </div>
        <!-- HOLD -->
        <div class="queue-card">
            <div class="card-header">
                HOLD QUEUE
            </div>
            <div id="holdQueueList">
                <div class="text-muted">
                    No hold patients
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/scanqueue.js" asp-append-version="true"></script>
}